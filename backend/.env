# Environment
RUST_ENV=development
RUST_LOG=dressly_backend=debug,actix_web=info

# Server
SERVER_HOST=0.0.0.0
SERVER_PORT=8080
SERVER_WORKERS=4

# Database
DATABASE_URL=postgres://dressly:dressly_secure_pwd@localhost:5432/dressly
DATABASE_MAX_CONNECTIONS=20
DATABASE_MIN_CONNECTIONS=2

# Redis
REDIS_URL=redis://localhost:6379
REDIS_MAX_CONNECTIONS=10

# JWT
JWT_SECRET=dressly-dev-jwt-secret-key-change-this-in-production-must-be-at-least-64-chars

# Gemini AI (placeholder - set your real key to enable AI features)
GEMINI_API_KEY=placeholder
GEMINI_MODEL=gemini-2.0-flash
GEMINI_API_URL=https://generativelanguage.googleapis.com/v1beta

# Razorpay (placeholder)
RAZORPAY_KEY_ID=placeholder
RAZORPAY_KEY_SECRET=placeholder
RAZORPAY_WEBHOOK_SECRET=placeholder

# FCM (placeholder)
FCM_SERVER_KEY=placeholder
FCM_PROJECT_ID=placeholder

# Storage (placeholder)
STORAGE_ENDPOINT=http://localhost:9000
STORAGE_ACCESS_KEY=placeholder
STORAGE_SECRET_KEY=placeholder
STORAGE_BUCKET=dressly-media
STORAGE_PUBLIC_URL=http://localhost:9000/dressly-media

# App Config
FREE_DAILY_AI_QUOTA=5
PRO_PRICE_INR=299
MAX_UPLOAD_SIZE_MB=10
MAX_IMAGES_PER_GENERATION=4

# Rate Limit
RATE_LIMIT_PER_MINUTE=100
RATE_LIMIT_BURST=20

# WebSocket
WS_HEARTBEAT_INTERVAL=10
WS_CLIENT_TIMEOUT=30
WS_MAX_MESSAGE_SIZE=65536
