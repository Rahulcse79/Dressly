# Environment
RUST_ENV=development
RUST_LOG=dressly_backend=debug,actix_web=info

# Server
SERVER_HOST=0.0.0.0
SERVER_PORT=8080
SERVER_WORKERS=4

# Database
DATABASE_URL=postgres://dressly:dressly_secure_pwd@localhost:5432/dressly
DATABASE_MAX_CONNECTIONS=100
DATABASE_MIN_CONNECTIONS=5

# Redis
REDIS_URL=redis://localhost:6379
REDIS_MAX_CONNECTIONS=50

# JWT
JWT_SECRET=your-ultra-secure-jwt-secret-change-in-production-min-64-chars-long-random
JWT_ACCESS_TOKEN_EXPIRY=900
JWT_REFRESH_TOKEN_EXPIRY=604800

# Gemini AI
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.0-flash
GEMINI_API_URL=https://generativelanguage.googleapis.com/v1beta

# Razorpay
RAZORPAY_KEY_ID=your-razorpay-key-id
RAZORPAY_KEY_SECRET=your-razorpay-key-secret
RAZORPAY_WEBHOOK_SECRET=your-razorpay-webhook-secret

# FCM (Firebase Cloud Messaging)
FCM_SERVER_KEY=your-fcm-server-key
FCM_PROJECT_ID=your-firebase-project-id

# Storage (S3-compatible / CloudFlare R2)
STORAGE_ENDPOINT=https://your-r2-endpoint.r2.cloudflarestorage.com
STORAGE_ACCESS_KEY=your-access-key
STORAGE_SECRET_KEY=your-secret-key
STORAGE_BUCKET=dressly-media
STORAGE_PUBLIC_URL=https://media.dressly.app

# App Config
FREE_DAILY_AI_QUOTA=5
PRO_PRICE_INR=299
MAX_UPLOAD_SIZE_MB=10
MAX_IMAGES_PER_GENERATION=4

# Rate Limiting
RATE_LIMIT_PER_MINUTE=100
RATE_LIMIT_BURST=20

# WebSocket
WS_HEARTBEAT_INTERVAL=10
WS_CLIENT_TIMEOUT=30
WS_MAX_MESSAGE_SIZE=65536
